# Minimum age before a published version is installable.
# npm reads this in DAYS (requires npm >= 11.7). pnpm uses
# `minimumReleaseAge` (minutes) in pnpm-workspace.yaml instead.
# 7 days
min-release-age=7

# Block lifecycle scripts (preinstall/postinstall/etc.) — the most common
# supply-chain attack vector. Allow per package with `pnpm approve-builds`
# or `npm rebuild <pkg> --foreground-scripts`.
ignore-scripts=true

# Fail `npm install` when audit reports moderate-or-higher advisories.
audit-level=moderate

# Suppress funding chatter on every install.
fund=false

# Refuse to install packages whose `engines` field rejects the current Node.
engine-strict=true